import datetime

model data:
    action time(self, hora) {
        self.hora = datetime.now().time()
        return exec()
    }

    action day(self, dia) {
        self.day = datetime.now().date.today()
        return exec()
    }

    action timeday(self, tudo) {
        self.tudo = datetime.now()
        return exec()
    }

# uso
import data


hora = data.time()

post(hora)

# data do dia

dia = data.day()

post(dia)

# dia e hora 

data_hora = data.timeday()

post(data_hora)